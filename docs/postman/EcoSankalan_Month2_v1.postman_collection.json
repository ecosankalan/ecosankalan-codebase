{
  "info": {
    "_postman_id": "c2b6e3d6-4b8a-4c51-a7f3-3b9c4d4f3a11",
    "name": "EcoSankalan — Month 2 Endpoints (v1)",
    "description": "Month 2 API collection covering: /auth/register, /auth/verify-otp, /auth/login, /auth/forgot-password, /auth/reset-password, GET /user/profile, PUT /user/profile.\n\nAuth: set {{token}} after login/verify-otp and it will be used as Bearer token.\nBase URL: {{baseUrl}} (default http://localhost:5000)\n\nExpected (high-level) responses:\n- /health -> 200 {\"status\":\"ok\"}\n- Duplicate email on register -> 409\n- Wrong password on login -> 401\n- Profile PUT with email/phone -> 400 message: 'Field not updatable post-registration'",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "otp", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test.user@example.com\",\n  \"phone\": \"9876543210\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "description": "Creates a new user, hashes password with bcrypt (12), generates OTP and triggers OTP send."
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["auth", "verify-otp"] },
            "description": "Verifies OTP and marks user as verified. Returns {token, user}."
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test.user@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Login using email+password OR phone+password. Returns {token, user} on success."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] },
            "description": "Sends OTP for password reset. Does not reveal whether phone exists."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"otp\": \"{{otp}}\",\n  \"newPassword\": \"NewPassword@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] },
            "description": "Verifies OTP and updates passwordHash (bcrypt 12)."
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/user/profile", "host": ["{{baseUrl}}"], "path": ["user", "profile"] },
            "description": "Returns user object (passwordHash excluded)."
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"area\": \"Dwarka Sector 10\",\n  \"avatarUrl\": \"https://res.cloudinary.com/demo/image/upload/v123/avatar.png\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/user/profile", "host": ["{{baseUrl}}"], "path": ["user", "profile"] },
            "description": "Allows updates to name, area, avatarUrl only. If email/phone is included -> 400 'Field not updatable post-registration'."
          }
        }
      ]
    }
  ]
}

