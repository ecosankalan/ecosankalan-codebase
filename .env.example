# ============================================================
# EcoSankalan — Environment Variables Template
# CPVS-STP 2025-26(E) | Project ID: STP2025-26(E)CSE(M)VivekAyush(2024UCS1573)
# ============================================================
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in real values in .env
#   3. NEVER commit .env to Git — it's in .gitignore
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=5000

# --- MongoDB Atlas (Atishay fills this in) ---
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/ecosankalan?retryWrites=true&w=majority

# --- JWT ---
# Use a long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING
JWT_EXPIRES_IN=7d

# --- OTP via MSG91 (Month 2 — leave blank for now) ---
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=ECOSNK

# --- Google Gemini API (Month 3 — ₹3,000 budget activates then) ---
GEMINI_API_KEY=

# --- Razorpay (Month 5) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Firebase FCM (Month 4) ---
FIREBASE_SERVER_KEY=

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- CORS ---
# In production, replace * with your actual frontend URL
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
